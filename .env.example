# Discord Configuration
# Get your token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_COMMAND_PREFIX=!

# RabbitMQ Configuration
# Default configuration for local development with Docker
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QUEUE_NAME=discord-commands
EXCHANGE_NAME=discord-exchange
ROUTING_KEY=discord.command

# Twitch Configuration (Optional - only if using Twitch features)
# Get your credentials from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Server Configuration
WEB_SERVER_PORT=8080

# Logging Configuration
# DEBUG_MODE: Enable debug logs (true/false) - Default: false
DEBUG_MODE=false
# LOG_LEVEL: Minimum log level to display (debug/info/warn/critical) - Default: info
LOG_LEVEL=info
